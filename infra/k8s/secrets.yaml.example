# Copy this to secrets.yaml, fill in base64-encoded values, and apply.
# NEVER commit secrets.yaml — it is gitignored.
#
# Encode a value:  echo -n "my-value" | base64
#
apiVersion: v1
kind: Secret
metadata:
  name: pulsecity-secrets
  namespace: pulsecity
type: Opaque
data:
  DATABASE_URL: <base64 of postgresql://user:pass@host:5432/pulsecity>
  SECRET_KEY: <base64 of your-jwt-secret-key>
  TICKETMASTER_API_KEY: <base64 of your-api-key>
