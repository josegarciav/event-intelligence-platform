# ============================================================================
# EVENT INTELLIGENCE PLATFORM - ENVIRONMENT VARIABLES EXAMPLE FORMAT
# Add your actual values in a .env file based on this template.
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------------------
ENV=development
DEBUG=false

# ----------------------------------------------------------------------------
# SOURCE API KEYS
# ----------------------------------------------------------------------------

# RA.CO - Electronic Music Platform (GraphQL, no key required for public events)
RA_CO_API_KEY=

# MEETUP - Community Events Platform (OAuth2 Bearer Token)
# Obtain at: https://www.meetup.com/api/oauth/list/
MEETUP_API_KEY=

# TICKETMASTER - Discovery API
# Obtain at: https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=

# TRIPADVISOR - Content API
# Obtain at: https://tripadvisor-content-api.readme.io/
TRIPADVISOR_API_KEY=

# CIVITATIS - Affiliate Activity API
# Obtain via Civitatis affiliate program
CIVITATIS_API_KEY=

# GETYOURGUIDE - Partner API
# Obtain via GetYourGuide partner program
GETYOURGUIDE_API_KEY=

# EVENTBRITE - REST API (OAuth token)
# Obtain at: https://www.eventbrite.com/platform/api-keys
EVENTBRITE_API_KEY=

# ----------------------------------------------------------------------------
# DATABASE
# ----------------------------------------------------------------------------
# SQLAlchemy-compatible URL
# Example:
# postgresql://user:password@localhost:5432/event_intelligence
DATABASE_URL=

# ----------------------------------------------------------------------------
# ENRICHMENT SERVICES
# ----------------------------------------------------------------------------

# FEATURE EXTRACTOR API KEYS
OPENAI_API_KEY =
ANTHROPIC_API_KEY =


# Geocoding provider API key
# Used when enrichment.geocoding.enabled = true
GEOCODING_API_KEY=

# ----------------------------------------------------------------------------
# MONITORING & ALERTING
# ----------------------------------------------------------------------------

# Sentry (error tracking)
SENTRY_DSN=

# Slack alerts (pipeline failures, quality issues, etc.)
SLACK_WEBHOOK=

# ----------------------------------------------------------------------------
# OPTIONAL / PIPELINE EXECUTION / FUTURE EXTENSIONS
# Global execution controls (not yet wired)
# ----------------------------------------------------------------------------

# MAX_CONCURRENT_PIPELINES=3


# Example placeholders for future services
# Redis for caching, deduplication, or rate limiting
# REDIS_URL=
# KAFKA_BROKER_URL=
# FEATURE_STORE_URL=

# ----------------------------------------------------------------------------
# MISC / LOCAL DEV
# ----------------------------------------------------------------------------
# Timezone used for local execution (optional)
# TZ=UTC


# Default locale (future i18n support)
# LOCALE=en_US
